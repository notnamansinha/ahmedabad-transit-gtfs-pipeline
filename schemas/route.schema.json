{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ahmedabad-transit-data/schemas/route.schema.json",
  "title": "TransitRoute",
  "description": "A bus/metro route. One record per route VARIANT (e.g. 1S, 1S-CG, 1S-JG are separate records). customer_route_code groups them.",
  "type": "object",
  "required": [
    "route_id",
    "agency",
    "route_code",
    "customer_route_code",
    "headsign",
    "start_stop_id",
    "end_stop_id",
    "stop_sequence",
    "first_departure",
    "last_departure",
    "operating_days",
    "sources",
    "scraped_at"
  ],
  "properties": {
    "route_id": {
      "type": "string",
      "description": "Canonical ID: '{agency}-{route_code}'. e.g. 'brt-1D', 'municipal_bus-65/2-SL-D'."
    },
    "agency": {"type": "string", "enum": ["brt", "municipal_bus", "metro"]},
    "route_code": {
      "type": "string",
      "description": "Internal operational code (may include direction/variant suffix)."
    },
    "customer_route_code": {
      "type": "string",
      "description": "User-facing route number (e.g. '1S', '65/2'). Multiple route_codes share this."
    },
    "headsign": {
      "type": "string",
      "description": "Human-readable 'A - B' route description."
    },
    "variant": {
      "type": "string",
      "enum": ["NORMAL", "AC", "LADIES_SPECIAL", "EXPRESS", "SHUTTLE", "OTHER"]
    },
    "start_stop_id": {"type": "string"},
    "end_stop_id": {"type": "string"},
    "stop_sequence": {
      "type": "array",
      "minItems": 0,
      "description": "Ordered stops on the route. Empty when the per-route API call failed; the route metadata is still kept for first/last/headsign info.",
      "items": {
        "type": "object",
        "required": ["sequence", "stop_id"],
        "properties": {
          "sequence": {"type": "integer", "minimum": 1},
          "stop_id": {"type": "string"},
          "stop_name": {"type": "string"},
          "expected_minutes_from_start": {"type": ["integer", "null"]}
        }
      }
    },
    "geometry": {
      "type": ["object", "null"],
      "description": "Route shape as GeoJSON LineString. Null when no per-route polyline was available. Coordinates in [lon, lat] order per RFC 7946.",
      "properties": {
        "type": {"const": "LineString"},
        "coordinates": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {"type": "number"},
            "minItems": 2,
            "maxItems": 2
          }
        }
      }
    },
    "first_departure": {
      "type": "string",
      "pattern": "^[0-9]{2}:[0-9]{2}(:[0-9]{2})?$"
    },
    "last_departure": {
      "type": "string",
      "pattern": "^[0-9]{2}:[0-9]{2}(:[0-9]{2})?$"
    },
    "operating_days": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 7,
        "description": "ISO-style: 1=Monday ... 7=Sunday. Note: the BRT/MUNICIPAL_BUS APIs use 1=Sunday; we normalize to ISO on ingest."
      }
    },
    "headway_minutes": {
      "type": ["object", "null"],
      "description": "Time-windowed frequency map: {'06:00-09:00': 7, '09:00-17:00': 12, ...}. Null when only first/last is known.",
      "additionalProperties": {"type": "number"}
    },
    "total_distance_km": {"type": ["number", "null"]},
    "total_duration_min": {"type": ["integer", "null"]},
    "sources": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "scraped_at": {"type": "string", "format": "date-time"},
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
